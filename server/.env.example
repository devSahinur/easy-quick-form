NODE_ENV=development
PORT=8000

# MongoDB connection string (e.g. from MongoDB Atlas)
DATABASE=

# JWT secrets — generate each with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# SMTP server for transactional emails (e.g. Brevo, Gmail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Google OAuth credentials (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Production frontend origin, added to the CORS allow-list (optional in local dev)
CLIENT_URL=

# Cloudinary — when set, profile pictures are uploaded here instead of local disk
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
